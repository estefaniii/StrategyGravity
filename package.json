{
  "name": "strategy-gravity",
  "version": "1.0.0",
  "description": "AI Marketing Strategy Agent - generates comprehensive 12-point marketing strategies with real web research",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:web": "tsx src/index.ts --web",
    "build": "tsc && cp -r src/web/public dist/web/public",
    "start": "node dist/index.js",
    "start:web": "node dist/index.js --web",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "groq-sdk": "^0.9.0",
    "inquirer": "^12.3.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.1",
    "pptxgenjs": "^4.0.1",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
